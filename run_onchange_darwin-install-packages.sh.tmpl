{{ if eq .chezmoi.os "darwin" }}
#!/bin/bash

# Trigger update on package changes: {{ .chezmoi.sourceFile | sha256sum }}
set -eufo pipefail

echo "Initializing macOS dependencies..."

# 1. Ensure Homebrew is in the current script's PATH
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# 2. Bootstrap Homebrew if actually missing from the system
if ! command -v brew &> /dev/null; then
    echo "Homebrew not found. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# 3. Idempotent Package Installation
# Note: Added zsh plugins so they exist in the paths defined in your .zshrc
brew bundle --no-lock --file=/dev/stdin <<'EOF'
brew "eza"
brew "fzf"
brew "zoxide"
brew "atuin"
brew "starship"
brew "mise"
brew "uv"
brew "tmux"
brew "bat"
brew "neovim"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"
cask "font-jetbrains-mono-nerd-font"
EOF

# 4. Runtime Configuration (Mise)
echo "Setting default versions via mise..."
# Ensure the script sees the mise binary just installed
export PATH="$(brew --prefix)/bin:$PATH"

if command -v mise &> /dev/null; then
    # Java 21 (LTS) for your Spring Boot / JVM work
    # Python 3.12+ for your AI Agentic / PyCharm workflows
    mise use --global java@temurin-21
    mise use --global python@latest
    mise use --global node@lts

    # Generate shims
    mise reshim
else
    echo "Error: mise still not found in PATH."
    exit 1
fi

# 5. FZF Cleanup
# We avoid the interactive $(brew --prefix)/opt/fzf/install
# because your .zshrc already handles the sourcing logic.
# This keeps your .zshrc from being 'vandalized' by the fzf installer.

echo "macOS dependencies synced, restart terminal"
{{ end }}
{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# macOS System Defaults Configuration
# This script is idempotent and runs whenever this file is updated.

echo "Applying macOS System Defaults..."

# ------------------------------------------------------------------------------
# KEYBOARD: Essential for Vim/IdeaVim users
# ------------------------------------------------------------------------------
# Disable press-and-hold for keys in favor of key repeat
defaults write -g ApplePressAndHoldEnabled -bool false

# Set a blazingly fast repeat rate (Minimum is 1, which is 15ms)
defaults write -g KeyRepeat -int 1
defaults write -g InitialKeyRepeat -int 10

# ------------------------------------------------------------------------------
# FINDER: Developer Visibility
# ------------------------------------------------------------------------------
# Show all filename extensions
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Show hidden files by default
defaults write com.apple.finder AppleShowAllFiles -bool true

# Keep folders on top when sorting by name
defaults write com.apple.finder _FXSortFoldersFirst -bool true

# Disable the warning when changing a file extension
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false

# ------------------------------------------------------------------------------
# DOCK & UI: Remove the friction
# ------------------------------------------------------------------------------
# Speed up Mission Control animations
defaults write com.apple.dock expose-animation-duration -float 0.1

# Remove the auto-hide delay for the Dock
defaults write com.apple.dock autohide-delay -float 0
defaults write com.apple.dock autohide-time-modifier -float 0.4

# Don't create .DS_Store files on network or USB volumes (Critical for cross-platform)
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true

# ------------------------------------------------------------------------------
# EXECUTION
# ------------------------------------------------------------------------------
# Restart affected applications
for app in "Finder" "Dock" "SystemUIServer"; do
    killall "$app" > /dev/null 2>&1
done

echo "macOS defaults applied. Note: Some changes may require a logout/login to take full effect."
{{ end -}}
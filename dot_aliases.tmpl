# ==========================================
# 1. NAV & DIRECTORIES
# ==========================================
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

if command -v eza >/dev/null 2>&1; then
    alias ls="eza --color=auto --group-directories-first --icons"
    alias ll="eza -l --icons --group-directories-first --git"
    alias la="eza -la --icons --group-directories-first --git"
    alias tree="eza --tree --level=2 --icons --git-ignore"
else
    {{ if eq .chezmoi.os "darwin" }}
    alias ls="ls -G"
    {{ else }}
    alias ls="ls --color=auto"
    {{ end }}
    alias ll="ls -lh"
    alias la="ls -lAh"
fi

alias c="clear"

# ==========================================
# 2. SYSTEM & CLIPBOARD
# ==========================================
alias rm="rm -i"
alias mv="mv -i"
alias cp="cp -i"

alias pbc="pbcopy"
alias pbp="pbpaste"
alias pbpwd='pwd | tr -d "\n" | pbcopy'
alias pblast='fc -ln -1 | sed "s/^[ \t]*//" | pbcopy'

{{ if eq .chezmoi.os "linux" }}
if [ -n "$WAYLAND_DISPLAY" ]; then
    alias pbcopy="wl-copy"
    alias pbpaste="wl-paste"
else
    alias pbcopy="xclip -selection clipboard"
    alias pbpaste="xclip -selection clipboard -o"
fi
{{ end }}

copybuffer() {
  printf "%s" "$BUFFER" | pbcopy
  zle redisplay
}
zle -N copybuffer
bindkey "^O" copybuffer

# ==========================================
# 3. SHELL MANAGEMENT
# ==========================================
alias h="history"
alias hcp='history 0 | fzf --tac --no-sort | pbcopy'
alias reload="source ~/.zshrc"

alias cz="chezmoi"
alias cza="chezmoi apply"
alias czd="chezmoi diff"
alias cze="chezmoi edit"
alias czs="chezmoi status"
alias edit-aliases="chezmoi edit ~/.aliases"
alias edit-zshrc="chezmoi edit ~/.zshrc"

# ==========================================
# 4. GIT
# ==========================================
alias g="git"
alias gst="git status -sb"
alias ga="git add"
alias gaa="git add --all"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gcmsg="git commit -m"
alias gcammend="git commit --amend --no-edit"
alias gp="git push"
alias gpf="git push --force-with-lease"
alias gpf!="git push --force"
alias gl="git pull --rebase --autostash"
alias gd='git diff --stat'
alias glog="git log --oneline --decorate --graph"
alias grecent="git for-each-ref --count=10 --sort=-committerdate refs/heads/ --format='%(refname:short)'"
alias clean-branches="git branch --merged | grep -v '\*' | xargs -n 1 git branch -d"
alias gcb-find='git branch -a | fzf | xargs -I {} git checkout $(echo {} | sed "s/.* //")'

# ==========================================
# 5. RUNTIMES
# ==========================================
alias mci="./mvnw clean install || mvn clean install"
alias mcp="./mvnw clean package || mvn clean package"
alias nr="npm run"
alias ni="npm install"
alias yi="yarn install"

nvmrc() {
  node -v > .nvmrc
  echo "Created .nvmrc with $(cat .nvmrc)"
}

# ==========================================
# 6. DOCKER
# ==========================================
alias d="docker"
alias dco="docker compose"
alias dex="docker exec -it"
alias dps="docker ps --format 'table {{ "{{.ID}}" }}\t{{ "{{.Names}}" }}\t{{ "{{.Status}}" }}\t{{ "{{.Ports}}" }}'"

# ==========================================
# 7. TERRAFORM
# ==========================================
alias tf="terraform"
alias tfa="terraform apply"
alias tfp="terraform plan"
alias tfi="terraform init"
alias tfscan="trivy config ."
alias tfl="tflint"
alias sec-check="tflint && trivy config . && trivy fs --scanners vuln,secret,config ."

# ==========================================
# 8. KUBERNETES
# ==========================================
alias k="kubectl"
alias kn='kubectl get nodes -o wide'
alias kpl='kubectl get pods | fzf | awk "{print \$1}" | xargs -I {} kubectl logs -f --tail=100 {}'

alias ocn='oc get nodes -o wide'
alias ocpl='oc get pods | fzf | awk "{print \$1}" | xargs -I {} oc logs -f --tail=100 {}'

# ==========================================
# 9. AWS
# ==========================================
alias awsl="aws configure list"
alias awsp='export AWS_PROFILE=$(aws configure list-profiles | fzf)'

# ==========================================
# 10. AZURE
# ==========================================
alias a="az"
alias al="az login"
alias als="az account list --output table"
alias arg="az group list --output table"
alias avm="az vm list --output table"
alias azsp='az account list --output json | jq -r ".[].name" | fzf | xargs -I {} az account set --subscription "{}"'
alias azrg-find="az group list --query '[].name' -o tsv | fzf | pbcopy"

# ==========================================
# 11. COOL PIPES
# ==========================================
alias pbjq='pbpaste | jq . | pbcopy'

# ==========================================
# 12. MODERN CLI REPLACEMENTS
# ==========================================
alias cat='bat'
alias find='fd'
alias grep='rg'
alias help='tldr'

alias vim='nvim'
alias vi='nvim'

# ==========================================
# 13. AI
# ==========================================
alias bundle="find . -maxdepth 2 -type f -not -path '*/.*' -not -path '*/node_modules/*' -not -path '*/target/*' | xargs tail -n +1"

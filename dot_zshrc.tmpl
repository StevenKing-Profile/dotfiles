# ==============================================================================
# 1. SYSTEM INITIALIZATION
# ==============================================================================

{{ if eq .chezmoi.os "darwin" }}
# Initialize Homebrew (Apple Silicon + Intel support)
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi
{{ end }}

# Initialize Mise (Universal Version Manager)
# Must happen before other tools to ensure runtimes (Node/Java/etc) are on PATH
if command -v mise &> /dev/null; then
    eval "$(mise activate zsh)"
fi

# ==============================================================================
# 2. ENVIRONMENT & PATH
# ==============================================================================
{{ if eq .chezmoi.os "linux" }}
export XCURSOR_THEME="catppuccin-mocha-dark-cursors"
export XCURSOR_SIZE=24
{{ end }}

export COLORTERM="truecolor"
export STARSHIP_CONFIG="$HOME/.config/starship.toml"

# Ensure local binaries take precedence over system binaries
export PATH="$HOME/.local/bin:$PATH"

# Source localized environment variables
[ -f "$HOME/.local/bin/env" ] && source "$HOME/.local/bin/env"
[ -f "$HOME/.atuin/bin/env" ] && source "$HOME/.atuin/bin/env"

# ==============================================================================
# 3. NATIVE ZSH HISTORY & COMPLETION
# ==============================================================================
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt appendhistory incappendhistory sharehistory

# Completion system (Required for tab-completion)
ZSH_COMPDUMP="${ZDOTDIR:-$HOME}/.zcompdump"
autoload -Uz compinit

# Enable extended globbing for the cache check
setopt extended_glob
if [[ -n ${ZSH_COMPDUMP}(#qN.m-1) ]]; then
    compinit -C -u
else
    compinit -u
fi
unsetopt extended_glob # Optional: disable it again if you don't use it elsewhere

# interactive
# Enable interactive completion menu
zstyle ':completion:*' menu select

# Use the same colors as your eza/LS_COLORS for the menu
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# Case-insensitive completion
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# Group results by category (files, commands, etc.)
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '-- %d --'

# ==============================================================================
# 4. TOOLCHAIN & WIZARD INTEGRATIONS
# ==============================================================================

# uv shell completions
if command -v uv &> /dev/null; then
    eval "$(uv generate-shell-completion zsh)"
fi

# macOS
if [[ -d "/opt/homebrew/opt/fzf" ]]; then
  source "/opt/homebrew/opt/fzf/shell/completion.zsh" 2> /dev/null
  source "/opt/homebrew/opt/fzf/shell/key-bindings.zsh"
# Linux/WSL fzf
elif [[ -f "/usr/share/doc/fzf/examples/key-bindings.zsh" ]]; then
  source "/usr/share/doc/fzf/examples/key-bindings.zsh"
fi

# atuin: SQLite shell history database
if command -v atuin &> /dev/null; then
    eval "$(atuin init zsh)"
fi

# starship: Prompt (Initialized before Zoxide to handle prompt redraws)
if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

# zoxide: Smart directory jumping (using --cmd cd to replace native cd)
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init zsh --cmd cd)"
fi

# ==============================================================================
# 5. KEYBINDINGS: XTERM STANDARDS
# ==============================================================================
bindkey -e # Emacs mode
bindkey "\e[1;5D" backward-word
bindkey "\e[1;5C" forward-word
bindkey "\e[3;5~" delete-word
bindkey '^H' backward-kill-word

[ -f ~/.local/share/zsh/alias-tips/alias-tips.plugin.zsh ] && source ~/.local/share/zsh/alias-tips/alias-tips.plugin.zsh

# ==============================================================================
# 6. UI PLUGINS (Manual Sourcing)
# ==============================================================================

# Check both standard Linux and Homebrew paths for stability
PLUGINS=(
    "$HOME/.local/share/zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"
    "$HOME/.local/share/zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    "/opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    "/opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
)

# Strict array iteration
for plugin in "${PLUGINS[@]}"; do
    [ -f "$plugin" ] && source "$plugin"
done

# ==============================================================================
# 7. EXTERNAL FILES
# ==============================================================================
[ -f "$HOME/.aliases" ] && source "$HOME/.aliases"
[ -f "$HOME/.zsh_functions" ] && source "$HOME/.zsh_functions"

# chezmoi
czeaa() {
  chezmoi edit ~/.aliases && chezmoi apply
  source ~/.zshrc
  echo "Aliases updated and sourced."
}

czeaz() {
  chezmoi edit ~/.zshrc && chezmoi apply
  source ~/.zshrc
  echo ".zshrc updated and sourced."
}

czeazf() {
  chezmoi edit ~/.zsh_functions && chezmoi apply
  source ~/.zshrc
  echo ".zsh_functions  updated and sourced."
}

